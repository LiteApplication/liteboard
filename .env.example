# LiteBoard configuration — copy to .env and fill in.

# Public URL where LiteBoard is reached (used for the OIDC redirect URI).
LITEBOARD_BASE_URL=https://liteboard.example.com

# Random secret for signing session cookies (e.g. `openssl rand -hex 32`).
LITEBOARD_SESSION_SECRET=change-me-to-a-long-random-string

# --- Authentik OIDC ---------------------------------------------------------
# Issuer = your Authentik application's OIDC issuer URL (note the trailing slash).
LITEBOARD_OIDC_ISSUER=https://authentik.example.com/application/o/liteboard/
LITEBOARD_OIDC_CLIENT_ID=your-client-id
LITEBOARD_OIDC_CLIENT_SECRET=your-client-secret
# Optional: only allow members of this Authentik group.
LITEBOARD_OIDC_REQUIRED_GROUP=

# --- Daemon signing ---------------------------------------------------------
# The server's Ed25519 PUBLIC key, printed by `make keygen`. The matching
# private key is provided to the server as the `liteboard_signing_key` secret.
LITEBOARD_SERVER_PUBKEY=paste-public-key-from-make-keygen

# --- Networking / tuning ----------------------------------------------------
LITEBOARD_PORT=8000
LITEBOARD_DAEMON_PORT=9187
LITEBOARD_POLL_INTERVAL=5

# --- Images (optional; set if you push to your own registry) ---------------
# LITEBOARD_IMAGE=registry.example.com/liteboard/server:latest
# LITEBOARD_DAEMON_IMAGE=registry.example.com/liteboard/daemon:latest
