# LiteBoard — OPTIONAL configuration.
#
# You do NOT need this file for a normal deploy. `docker stack deploy` boots the
# server unconfigured and you finish setup in the first-login wizard (the setup
# token is printed to `docker service logs liteboard_server`).
#
# These variables only tweak the stack file itself (image/port). Note that
# `docker stack deploy` does not read .env automatically — export them first
# (`set -a; source .env; set +a`) or use `docker compose` for local builds.

# Published port for the SPA/API (terminate TLS in front of this).
LITEBOARD_PORT=8000

# Port the per-node daemons listen on (host mode).
LITEBOARD_DAEMON_PORT=9187

# Seconds between node polls / SSE ticks.
LITEBOARD_POLL_INTERVAL=5

# --- Images (optional; override the default GHCR images) --------------------
# LITEBOARD_IMAGE=ghcr.io/liteapplication/liteboard/server:latest
# LITEBOARD_DAEMON_IMAGE=ghcr.io/liteapplication/liteboard/daemon:latest

# --- Advanced: skip the wizard by baking config into the server env ---------
# If you set ALL of these, the server boots already-configured (no wizard).
# You must then also provide a signing key (Docker secret or bind mount) — see
# README "Advanced: pre-provisioning".
# LITEBOARD_BASE_URL=https://liteboard.example.com
# LITEBOARD_OIDC_ISSUER=https://authentik.example.com/application/o/liteboard/
# LITEBOARD_OIDC_CLIENT_ID=your-client-id
# LITEBOARD_OIDC_CLIENT_SECRET=your-client-secret
# LITEBOARD_OIDC_REQUIRED_GROUP=
